# Production Environment Configuration
# This file is used for live production deployment

# ============================================================
# LLM API KEYS
# ============================================================

# Together AI (Free Tier - Requires dedicated endpoint setup)
# NOTE: API key is stored in /secrets/.env-together (gitignored)
TOGETHER_API_KEY=${TOGETHER_API_KEY}

# Hugging Face (Currently Not Working - API Deprecated)
# NOTE: API key is stored in /secrets/.env-huggingface (gitignored)
HUGGINGFACE_API_KEY=${HUGGINGFACE_API_KEY}

# OpenRouter (FREE - Using Step 3.5 Flash via stepfun)
# NOTE: API key is stored in /secrets/.env-openrouter (gitignored)
OPENROUTER_API_KEY=${OPENROUTER_API_KEY}

# ============================================================
# LLM PROVIDER CONFIGURATION
# ============================================================

# Provider order (comma-separated, left to right priority)
# BOTH PROVIDERS ARE COMPLETELY FREE!
# Primary: Step 3.5 Flash (free via OpenRouter)
# Fallback: ServiceNow Apriel 1.5 (free via Together.ai)
LLM_PROVIDER_ORDER=openrouter,together

# ============================================================
# IMAGE API KEYS (Optional)
# ============================================================

# The Cat API (Free tier: 10,000 requests/month)
CAT_API_KEY=your_cat_api_key_here

# Unsplash API (Free tier: 50 requests/hour)
UNSPLASH_ACCESS_KEY=your_unsplash_key_here

# Pexels API (Free tier: 200 requests/hour)
PEXELS_API_KEY=your_pexels_key_here

# ============================================================
# ENVIRONMENT SETTINGS
# ============================================================

NODE_ENV=production
NEXT_PUBLIC_API_URL=https://aibreed-demo.com

# ============================================================
# CACHE SETTINGS
# ============================================================

# Cache expiration in days
CACHE_EXPIRATION_DAYS=7

# Maximum cache size in MB
MAX_CACHE_SIZE_MB=1000

# ============================================================
# SECURITY SETTINGS
# ============================================================

# Rate limiting (requests per minute per IP)
RATE_LIMIT_RPM=60

# Enable CORS (for API access from other domains)
ENABLE_CORS=false

# Allowed origins (comma-separated, only if CORS enabled)
ALLOWED_ORIGINS=https://aibreeds-demo.com
